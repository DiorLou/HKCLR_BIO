   <string notr="true">#PasswordConfirmForm {
	background-color: rgb(230, 230, 239);
}

#edit_passwd  {
	background-color:white;
}

#pbn_cancel 
{
	background-color:white;
	border:none;
    border-radius: 4px;
}

#pbn_submit {
 	background: rgb(41, 90, 176);
	border:none;
    border-radius: 4px;
	color: rgb(255, 255, 255);
}

#pbn_close {
	background-color:transparent;
	border:none;
}

QWidget#wgt_passwd{
	background-color: white;
	border: 1px solid rgba(130, 130, 130, 180);
	border-radius:4px;
}

QWidget#wgt_passwd QLineEdit
{
    background-color:transparent;
	border: none;
	border-top-left-radius:4px;
    border-bottom-left-radius:4px;
}

QPushButton#pbn_eye {
	background: transparent;
	border: none;
	border-top-right-radius:4px;
    border-bottom-right-radius:4px;
	border-image: url(:/settings/image/settings/pwd_show.svg);
	margin: 4px;
}

QWidget#wgt_passwd QPushButton#pbn_eye:checked {
	background: transparent;
	border: none;
	border-top-right-radius:4px;
    border-bottom-right-radius:4px;
	border-image: url(:/settings/image/settings/pwd_hide.svg);
}

</string>
