  <property name="styleSheet">
   <string notr="true">QPushButton#pbn_back,
QPushButton#pbn_close {
	background: transparent;
	border: none;
}

QPushButton#pbn_confirm {
    background: rgb(41, 90, 176);
	border:none;
    border-radius: 4px;
	color: rgb(255, 255, 255);
	font-size:14px;
}

QPushButton#pbn_confirm:disabled {
    background: rgba(41, 90, 176, 0.6);
}

QLabel#lbl_authority,
QLabel#lbl_password {
	background: transparent;
	border:none;
	color: rgb(125, 134, 157);
}

QWidget#widget_password{
	background-color: rgb(255, 255, 255);
	border: 1px solid rgb(217, 217, 217);
	border-radius:4px;
}

QWidget#widget_password QLineEdit
{
    background-color:transparent;
	border: none;
	border-top-left-radius:4px;
    border-bottom-left-radius:4px;
	padding-left: 8px;
}

QPushButton#pbn_eye {
	background: transparent;
	border: none;
	border-top-right-radius:4px;
    border-bottom-right-radius:4px;
	border-image: url(:/settings/image/settings/pwd_show.svg);
	margin: 5px 8px 5px 5px;
}

QWidget#widget_password QPushButton#pbn_eye:checked {
	background: transparent;
	border: none;
	border-top-right-radius:4px;
    border-bottom-right-radius:4px;
	border-image: url(:/settings/image/settings/pwd_hide.svg);
}

QLabel#lbl_title{
	font-size:16px;
}
</string>
